<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
<script>
(function () {
  const canvas = document.getElementById('robot-canvas');
  const W = canvas.offsetWidth, H = canvas.offsetHeight;
  canvas.width = W * window.devicePixelRatio;
  canvas.height = H * window.devicePixelRatio;

  const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
  renderer.setPixelRatio(window.devicePixelRatio);
  renderer.setSize(W, H);
  renderer.shadowMap.enabled = true;
  renderer.shadowMap.type = THREE.PCFSoftShadowMap;
  renderer.toneMapping = THREE.ACESFilmicToneMapping;
  renderer.toneMappingExposure = 1.2;

  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(42, W / H, 0.1, 100);
  camera.position.set(2.8, 2.2, 3.5);
  camera.lookAt(0, 1.2, 0);

  scene.add(new THREE.AmbientLight(0x0d1a2d, 2));
  const key = new THREE.DirectionalLight(0x00c8ff, 3.5);
  key.position.set(3, 5, 3); key.castShadow = true;
  key.shadow.mapSize.set(1024, 1024);
  scene.add(key);
  const fill = new THREE.DirectionalLight(0x0062ff, 1.5);
  fill.position.set(-3, 2, -2); scene.add(fill);
  const rim = new THREE.DirectionalLight(0x7b2fff, 2);
  rim.position.set(0, -1, -4); scene.add(rim);
  const bottom = new THREE.PointLight(0x00e5a0, 0.8, 8);
  bottom.position.set(0, -1, 1); scene.add(bottom);

  const matBody = new THREE.MeshStandardMaterial({ color: 0x1a2a3a, metalness: 0.85, roughness: 0.18 });
  const matJoint = new THREE.MeshStandardMaterial({ color: 0x0e1c2c, metalness: 0.9, roughness: 0.1 });
  const matAccent = new THREE.MeshStandardMaterial({ color: 0x00c8ff, metalness: 0.6, roughness: 0.3, emissive: 0x004466, emissiveIntensity: 0.5 });
  const matBase = new THREE.MeshStandardMaterial({ color: 0x0a1520, metalness: 0.7, roughness: 0.3 });

  const cyl = (rt, rb, h, mat, s = 32) => new THREE.Mesh(new THREE.CylinderGeometry(rt, rb, h, s), mat);
  const box = (w, h, d, mat) => new THREE.Mesh(new THREE.BoxGeometry(w, h, d), mat);
  const tor = (r, t, mat) => new THREE.Mesh(new THREE.TorusGeometry(r, t, 16, 48), mat);

  const root = new THREE.Group();
  scene.add(root);

  // Base
  const base = cyl(0.55, 0.65, 0.12, matBase); base.position.y = 0.06; root.add(base);
  const baseCol = cyl(0.42, 0.42, 0.22, matBody); baseCol.position.y = 0.23; root.add(baseCol);
  const baseRing = tor(0.42, 0.025, matAccent); baseRing.rotation.x = Math.PI / 2; baseRing.position.y = 0.28; root.add(baseRing);

  // J1 shoulder
  const j1 = new THREE.Group(); j1.position.y = 0.36; root.add(j1);
  const shoulder = cyl(0.38, 0.38, 0.28, matJoint); shoulder.rotation.z = Math.PI / 2; j1.add(shoulder);
  const sCap1 = cyl(0.18, 0.22, 0.06, matAccent); sCap1.rotation.z = Math.PI / 2; sCap1.position.x = 0.17; j1.add(sCap1);
  const sCap2 = sCap1.clone(); sCap2.position.x = -0.17; j1.add(sCap2);

  // Upper arm
  const j2 = new THREE.Group(); j2.position.set(0.28, 0, 0); j1.add(j2);
  const ua = cyl(0.1, 0.1, 0.82, matBody); ua.rotation.z = Math.PI / 2; ua.position.x = 0.41; j2.add(ua);
  const s1 = cyl(0.105, 0.105, 0.06, matAccent); s1.rotation.z = Math.PI / 2; s1.position.x = 0.28; j2.add(s1);
  const s2 = s1.clone(); s2.position.x = 0.58; j2.add(s2);

  // Elbow
  const j3 = new THREE.Group(); j3.position.set(0.84, 0, 0); j2.add(j3);
  const elbow = cyl(0.14, 0.14, 0.26, matJoint); elbow.rotation.z = Math.PI / 2; j3.add(elbow);
  const eRing = tor(0.14, 0.018, matAccent); eRing.rotation.x = Math.PI / 2; j3.add(eRing);

  // Forearm
  const j4 = new THREE.Group(); j4.position.set(0.14, 0, 0); j3.add(j4);
  const fa = cyl(0.09, 0.09, 0.65, matBody); fa.rotation.z = Math.PI / 2; fa.position.x = 0.325; j4.add(fa);
  const s3 = cyl(0.095, 0.095, 0.05, matAccent); s3.rotation.z = Math.PI / 2; s3.position.x = 0.18; j4.add(s3);

  // Wrist 1
  const j5 = new THREE.Group(); j5.position.set(0.65, 0, 0); j4.add(j5);
  const w1 = cyl(0.12, 0.12, 0.18, matJoint); w1.rotation.z = Math.PI / 2; j5.add(w1);

  // Wrist 2
  const j6 = new THREE.Group(); j6.position.set(0.09, 0, 0); j5.add(j6);
  const w2 = cyl(0.11, 0.11, 0.14, matBody); j6.add(w2);
  const wR = tor(0.11, 0.015, matAccent); wR.rotation.x = Math.PI / 2; wR.position.y = 0.05; j6.add(wR);

  // Tool flange + gripper
  const j7 = new THREE.Group(); j7.position.set(0, 0.14, 0); j6.add(j7);
  const flange = cyl(0.09, 0.09, 0.06, matJoint); j7.add(flange);
  const gBase = cyl(0.07, 0.07, 0.04, matJoint); gBase.position.y = 0.05; j7.add(gBase);

  function makeFinger(xOff) {
    const g = new THREE.Group();
    const upper = box(0.025, 0.12, 0.04, matBody); upper.position.y = 0.09; g.add(upper);
    const lower = box(0.02, 0.09, 0.035, matAccent); lower.position.y = 0.165; g.add(lower);
    g.position.x = xOff; return g;
  }
  const f1 = makeFinger(0.055); j7.add(f1);
  const f2 = makeFinger(-0.055); j7.add(f2);

  // Lab plate
  const plate = box(0.18, 0.015, 0.12, new THREE.MeshStandardMaterial({ color: 0x002244, metalness: 0.1, roughness: 0.8, transparent: true, opacity: 0.85 }));
  plate.position.y = 0.31; j7.add(plate);
  for (let r = 0; r < 3; r++) for (let c = 0; c < 4; c++) {
    const well = cyl(0.01, 0.01, 0.012, new THREE.MeshStandardMaterial({ color: 0x00c8ff, emissive: 0x003344, emissiveIntensity: 0.4 }));
    well.position.set(-0.06 + c * 0.04, 0.315, -0.04 + r * 0.04); j7.add(well);
  }

  // Floor
  const floor = new THREE.Mesh(new THREE.CircleGeometry(2, 64), new THREE.MeshStandardMaterial({ color: 0x040810 }));
  floor.rotation.x = -Math.PI / 2; floor.receiveShadow = true; scene.add(floor);

  const glow = new THREE.PointLight(0x00c8ff, 1.2, 2.5);
  glow.position.set(0, 0.05, 0); scene.add(glow);

  let t = 0, cycles = 0, lastCycle = 0;

  function animate() {
    requestAnimationFrame(animate);
    t += 0.008;
    j1.rotation.y = Math.sin(t * 0.4) * 0.6;
    j2.rotation.z = -0.3 + Math.sin(t * 0.5 + 0.5) * 0.25;
    j3.rotation.z = 0.6 + Math.sin(t * 0.6 + 1.0) * 0.3;
    j4.rotation.x = Math.sin(t * 0.7 + 2.0) * 0.4;
    j5.rotation.z = Math.sin(t * 0.9 + 0.8) * 0.35;
    j6.rotation.y = t * 0.6;
    const grip = Math.max(0, Math.sin(t * 1.2)) * 0.02;
    f1.position.x = 0.055 + grip;
    f2.position.x = -0.055 - grip;
    glow.intensity = 0.8 + Math.sin(t * 2) * 0.4;
    if (t - lastCycle > 4) { lastCycle = t; document.getElementById('cycle-count').textContent = ++cycles; }
    camera.position.x = 2.8 * Math.cos(t * 0.04);
    camera.position.z = 3.5 * Math.sin(t * 0.04 + 0.5);
    camera.lookAt(0, 1.2, 0);
    renderer.render(scene, camera);
  }
  animate();

  setInterval(() => {
    const el = document.getElementById('m-samples');
    el.textContent = (parseInt(el.textContent.replace(',', '')) + Math.floor(Math.random() * 3 + 1)).toLocaleString();
  }, 3000);
})();

const MICROSCOPE = 'http://localhost:5050';
let captureCount = 0;
let lastBlob = null;

function setServerOnline() {
  document.getElementById('cam-offline-badge').style.display = 'none';
  document.getElementById('mic-status').textContent = 'Online — ready to capture';
  document.getElementById('mic-status').style.color = 'var(--success)';
}

function setServerOffline() {
  document.getElementById('cam-offline-badge').style.display = 'flex';
  document.getElementById('mic-status').textContent = 'Offline — run microscope_server.py';
  document.getElementById('mic-status').style.color = 'var(--muted)';
}

function showImage(blob, ts) {
  const url = URL.createObjectURL(blob);
  const img = document.getElementById('mic-img');
  img.src = url;
  img.style.display = 'block';
  document.getElementById('cam-offline').style.display = 'none';
  document.getElementById('cam-ts-badge').style.display = 'flex';
  document.getElementById('cam-ts-text').textContent = ts;
  document.getElementById('last-snap').textContent = ts;
  document.getElementById('last-snap').style.color = 'var(--success)';
  lastBlob = blob;
}

function captureNew() {
  const btn = document.getElementById('cap-btn');
  btn.textContent = '⏳ Capturing…';
  btn.disabled = true;
  fetch(MICROSCOPE + '/capture')
    .then(r => {
      if (!r.ok) throw new Error('Capture failed');
      const ts = r.headers.get('X-Timestamp') || new Date().toLocaleString();
      return r.blob().then(blob => ({ blob, ts }));
    })
    .then(({ blob, ts }) => {
      captureCount++;
      document.getElementById('total-caps').textContent = captureCount;
      showImage(blob, ts);
    })
    .catch(e => {
      alert('Capture failed — is microscope_server.py running?\n' + e.message);
    })
    .finally(() => {
      btn.textContent = '📷 Capture';
      btn.disabled = false;
    });
}

function downloadImage() {
  if (!lastBlob) { alert('No image captured yet.'); return; }
  const ts = new Date().toISOString().replace(/[:.]/g, '-');
  const a = document.createElement('a');
  a.href = URL.createObjectURL(lastBlob);
  a.download = 'microscope_' + ts + '.jpg';
  a.click();
}

function toggleFullscreen() {
  const frame = document.getElementById('cam-frame');
  if (!document.fullscreenElement) frame.requestFullscreen();
  else document.exitFullscreen();
}

// Check server status + load existing image on page load
function checkStatus() {
  fetch(MICROSCOPE + '/status')
    .then(r => r.json())
    .then(d => {
      setServerOnline();
      // Load existing image if available and none shown yet
      if (d.hasImage && document.getElementById('mic-img').style.display === 'none') {
        fetch(MICROSCOPE + '/image?t=' + Date.now())
          .then(r => r.blob())
          .then(blob => showImage(blob, 'Previous capture'));
      }
    })
    .catch(() => setServerOffline());
}

// Load image immediately on page open
const _img = document.getElementById('mic-img');
_img.src = '/image?t=' + Date.now();
_img.style.display = 'block';
_img.onerror = () => { _img.style.display = 'none'; document.getElementById('cam-offline').style.display = 'flex'; };

checkStatus();
setInterval(checkStatus, 4000);
</script>

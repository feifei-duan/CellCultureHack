<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>LabForge — UR12e Automated Lab</title>
  <style>
    :root {
      --bg: #080d14;
      --surface: #0e1623;
      --card: #111d2e;
      --border: #1a2d45;
      --accent: #00c8ff;
      --accent2: #0062ff;
      --accent3: #7b2fff;
      --text: #e8f0fe;
      --muted: #5a7a9a;
      --success: #00e5a0;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: var(--bg); color: var(--text); font-family: 'Segoe UI', system-ui, sans-serif; overflow-x: hidden; }

    nav {
      position: fixed; top: 0; width: 100%; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1rem 3rem;
      background: rgba(8,13,20,0.88); backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
    }
    .logo { display: flex; align-items: center; gap: 0.6rem; font-size: 1.2rem; font-weight: 700; }
    .logo-icon { width: 32px; height: 32px; background: linear-gradient(135deg,var(--accent),var(--accent2)); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 1rem; }
    .nav-links { display: flex; gap: 2.5rem; font-size: 0.9rem; }
    .nav-links a { color: var(--muted); text-decoration: none; transition: color .2s; }
    .nav-links a:hover { color: var(--text); }
    .nav-cta { background: var(--accent2); color: #fff; border: none; padding: 0.55rem 1.4rem; border-radius: 8px; font-size: 0.9rem; cursor: pointer; transition: opacity .2s; }
    .nav-cta:hover { opacity: 0.85; }

    .hero {
      min-height: 100vh; display: grid; grid-template-columns: 1fr 1fr;
      align-items: center; gap: 2rem; padding: 8rem 3rem 4rem;
    }
    .hero-text { max-width: 540px; }
    .badge {
      display: inline-flex; align-items: center; gap: 0.5rem;
      background: rgba(0,200,255,0.08); border: 1px solid rgba(0,200,255,0.25);
      padding: 0.3rem 0.9rem; border-radius: 100px; font-size: 0.78rem; color: var(--accent); margin-bottom: 1.4rem;
    }
    .badge-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); animation: pulse 1.8s infinite; }
    @keyframes pulse { 0%,100%{opacity:1}50%{opacity:0.3} }
    h1 { font-size: clamp(2.2rem,4vw,3.4rem); line-height: 1.1; font-weight: 800; letter-spacing: -1px; margin-bottom: 1.2rem; }
    h1 span { background: linear-gradient(90deg,var(--accent),var(--accent2)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .hero-sub { font-size: 1.05rem; color: var(--muted); line-height: 1.7; margin-bottom: 2rem; }
    .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
    .btn-primary { background: linear-gradient(135deg,var(--accent2),var(--accent3)); color: #fff; border: none; padding: 0.8rem 2rem; border-radius: 10px; font-size: 1rem; font-weight: 600; cursor: pointer; transition: transform .2s, box-shadow .2s; }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(0,98,255,.35); }
    .btn-ghost { background: transparent; color: var(--text); border: 1px solid var(--border); padding: 0.8rem 2rem; border-radius: 10px; font-size: 1rem; cursor: pointer; transition: border-color .2s; }
    .btn-ghost:hover { border-color: var(--accent); }
    .hero-stats { display: flex; gap: 2.5rem; margin-top: 2.5rem; }
    .stat-item .stat-val { font-size: 1.6rem; font-weight: 800; color: var(--accent); }
    .stat-item .stat-label { font-size: 0.78rem; color: var(--muted); margin-top: 0.1rem; }

    .hero-visual { position: relative; display: flex; align-items: center; justify-content: center; }
    #robot-canvas {
      width: 100%; max-width: 600px; height: 520px; border-radius: 24px; display: block;
      background: radial-gradient(ellipse at 40% 40%,rgba(0,98,255,.08) 0%,rgba(8,13,20,0) 70%),
                  radial-gradient(ellipse at 70% 70%,rgba(123,47,255,.06) 0%,transparent 60%), var(--card);
      border: 1px solid var(--border);
    }
    .canvas-overlay {
      position: absolute; bottom: 24px; left: 50%; transform: translateX(-50%);
      background: rgba(14,22,35,0.85); backdrop-filter: blur(8px);
      border: 1px solid var(--border); border-radius: 12px;
      padding: 0.6rem 1.4rem; display: flex; align-items: center; gap: 1.2rem;
      font-size: 0.78rem; white-space: nowrap;
    }
    .canvas-overlay span { color: var(--muted); }
    .canvas-overlay strong { color: var(--accent); }
    .status-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--success); animation: pulse 2s infinite; }

    .section { padding: 6rem 3rem; }
    .section-label { font-size: 0.78rem; letter-spacing: 2px; text-transform: uppercase; color: var(--accent); margin-bottom: 0.8rem; }
    .section-title { font-size: clamp(1.8rem,3vw,2.6rem); font-weight: 800; letter-spacing: -.5px; margin-bottom: 1rem; }
    .section-sub { color: var(--muted); max-width: 500px; line-height: 1.7; }

    .features-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem; margin-top: 3.5rem; }
    .feature-card {
      background: var(--card); border: 1px solid var(--border); border-radius: 16px;
      padding: 1.8rem; transition: border-color .25s, transform .25s;
    }
    .feature-card:hover { border-color: rgba(0,200,255,.3); transform: translateY(-4px); }
    .feature-icon { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.3rem; margin-bottom: 1.1rem; }
    .feature-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: .5rem; }
    .feature-card p { font-size: .87rem; color: var(--muted); line-height: 1.6; }

    .specs-section { background: var(--surface); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
    .specs-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
    .specs-table { width: 100%; border-collapse: collapse; margin-top: 2rem; }
    .specs-table tr { border-bottom: 1px solid var(--border); }
    .specs-table tr:last-child { border-bottom: none; }
    .specs-table td { padding: .85rem 0; font-size: .9rem; }
    .specs-table td:first-child { color: var(--muted); width: 50%; }
    .specs-table td:last-child { font-weight: 600; }
    .spec-highlight { color: var(--accent) !important; }
    .spec-visual { background: var(--card); border: 1px solid var(--border); border-radius: 20px; padding: 2rem; display: flex; flex-direction: column; gap: 1.2rem; }
    .spec-bar-label { display: flex; justify-content: space-between; font-size: .82rem; margin-bottom: .4rem; }
    .spec-bar-label span:last-child { color: var(--accent); font-weight: 600; }
    .spec-bar-track { height: 6px; background: var(--border); border-radius: 100px; overflow: hidden; }
    .spec-bar-fill { height: 100%; border-radius: 100px; background: linear-gradient(90deg,var(--accent2),var(--accent)); }

    .workflow-steps { display: grid; grid-template-columns: repeat(4,1fr); gap: 0; margin-top: 3.5rem; position: relative; }
    .workflow-steps::before { content:''; position: absolute; top: 28px; left: 10%; right: 10%; height: 1px; background: linear-gradient(90deg,transparent,var(--border),var(--border),transparent); }
    .workflow-step { text-align: center; padding: 0 1rem; }
    .step-num { width: 56px; height: 56px; border-radius: 50%; margin: 0 auto 1.2rem; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 1.1rem; border: 2px solid var(--border); background: var(--card); position: relative; z-index: 1; transition: border-color .2s; }
    .workflow-step:hover .step-num { border-color: var(--accent); color: var(--accent); }
    .workflow-step h4 { font-size: .95rem; font-weight: 700; margin-bottom: .4rem; }
    .workflow-step p { font-size: .82rem; color: var(--muted); line-height: 1.55; }

    .dashboard-grid { display: grid; grid-template-columns: 1fr 1.4fr; gap: 2rem; margin-top: 3.5rem; align-items: start; }
    .metric-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .metric-card { background: var(--card); border: 1px solid var(--border); border-radius: 14px; padding: 1.4rem; }
    .metric-card .metric-val { font-size: 2rem; font-weight: 800; line-height: 1; }
    .metric-card .metric-label { font-size: .78rem; color: var(--muted); margin-top: .3rem; }
    .metric-card .metric-trend { font-size: .75rem; color: var(--success); margin-top: .5rem; }

    .status-panel { background: var(--card); border: 1px solid var(--border); border-radius: 20px; padding: 2rem; }
    .panel-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
    .panel-header h3 { font-size: 1rem; font-weight: 700; }
    .live-badge { display: flex; align-items: center; gap: .4rem; font-size: .75rem; color: var(--success); }
    .task-row { display: flex; align-items: center; gap: 1rem; padding: .75rem 0; border-bottom: 1px solid var(--border); }
    .task-row:last-child { border-bottom: none; }
    .task-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
    .task-name { flex: 1; font-size: .88rem; }
    .task-status { font-size: .75rem; font-weight: 600; padding: .2rem .7rem; border-radius: 100px; }
    .s-running { background: rgba(0,200,255,.1); color: var(--accent); }
    .s-queued { background: rgba(90,122,154,.15); color: var(--muted); }
    .s-done { background: rgba(0,229,160,.1); color: var(--success); }
    .task-time { font-size: .78rem; color: var(--muted); min-width: 48px; text-align: right; }

    /* CAMERA FEED */
    .camera-section { padding: 0 3rem 6rem; }
    .camera-grid { display: grid; grid-template-columns: 1.6fr 1fr; gap: 2rem; margin-top: 3.5rem; align-items: start; }
    .camera-frame {
      background: #000; border: 1px solid var(--border); border-radius: 20px;
      overflow: hidden; position: relative; aspect-ratio: 16/9;
    }
    .camera-frame img {
      width: 100%; height: 100%; object-fit: cover; display: block;
    }
    .camera-frame .cam-offline {
      position: absolute; inset: 0; display: flex; flex-direction: column;
      align-items: center; justify-content: center; gap: 0.8rem;
      background: var(--card); color: var(--muted); font-size: 0.9rem;
    }
    .cam-offline .cam-icon { font-size: 2.5rem; opacity: 0.4; }
    .cam-badge {
      position: absolute; top: 14px; left: 14px;
      display: flex; align-items: center; gap: 0.5rem;
      background: rgba(0,0,0,0.6); backdrop-filter: blur(8px);
      border: 1px solid rgba(255,255,255,0.1); border-radius: 8px;
      padding: 0.3rem 0.8rem; font-size: 0.75rem; font-weight: 600;
    }
    .cam-badge.live { color: #ff4444; }
    .cam-badge.live .rec-dot { width: 7px; height: 7px; border-radius: 50%; background: #ff4444; animation: pulse 1s infinite; }
    .cam-badge.offline-badge { color: var(--muted); }
    .cam-controls {
      position: absolute; bottom: 14px; right: 14px; display: flex; gap: 0.5rem;
    }
    .cam-btn {
      background: rgba(0,0,0,0.6); backdrop-filter: blur(8px);
      border: 1px solid rgba(255,255,255,0.1); border-radius: 8px;
      color: var(--text); padding: 0.4rem 0.8rem; font-size: 0.78rem; cursor: pointer;
      transition: border-color .2s;
    }
    .cam-btn:hover { border-color: var(--accent); color: var(--accent); }
    .cam-info { display: flex; flex-direction: column; gap: 1rem; }
    .cam-stat-card { background: var(--card); border: 1px solid var(--border); border-radius: 14px; padding: 1.3rem; }
    .cam-stat-card .cs-label { font-size: 0.75rem; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.5rem; }
    .cam-stat-card .cs-val { font-size: 1.1rem; font-weight: 700; }
    .ip-input-row { display: flex; gap: 0.6rem; margin-top: 0.6rem; }
    .ip-input { background: var(--surface); border: 1px solid var(--border); color: var(--text); padding: 0.5rem 0.8rem; border-radius: 8px; font-size: 0.85rem; flex: 1; outline: none; transition: border-color .2s; }
    .ip-input:focus { border-color: var(--accent); }
    .ip-connect-btn { background: var(--accent2); color: #fff; border: none; padding: 0.5rem 1rem; border-radius: 8px; font-size: 0.85rem; cursor: pointer; font-weight: 600; white-space: nowrap; }

    footer { border-top: 1px solid var(--border); padding: 2.5rem 3rem; display: flex; justify-content: space-between; align-items: center; font-size: .82rem; color: var(--muted); }
    .footer-links { display: flex; gap: 2rem; }
    .footer-links a { color: var(--muted); text-decoration: none; }
    .footer-links a:hover { color: var(--text); }
  </style>
</head>
<body>

<nav>
  <div class="logo">
    <div class="logo-icon">⚗</div>
    LabForge
  </div>
  <div class="nav-links">
    <a href="#">Platform</a>
    <a href="#">UR12e</a>
    <a href="#">Integrations</a>
    <a href="#">Docs</a>
    <a href="#">Pricing</a>
  </div>
  <button class="nav-cta">Request Demo</button>
</nav>

<section class="hero">
  <div class="hero-text">
    <div class="badge"><span class="badge-dot"></span> UR12e Now Available</div>
    <h1>Lab Automation<br>at <span>Robotic Precision</span></h1>
    <p class="hero-sub">Deploy the UR12e collaborative robot arm into your lab workflow. Automate pipetting, sample handling, and plate management — 24/7 with zero downtime.</p>
    <div class="hero-actions">
      <button class="btn-primary">Get Started Free</button>
      <button class="btn-ghost">Watch Demo ▶</button>
    </div>
    <div class="hero-stats">
      <div class="stat-item"><div class="stat-val">12kg</div><div class="stat-label">Payload</div></div>
      <div class="stat-item"><div class="stat-val">±0.03mm</div><div class="stat-label">Repeatability</div></div>
      <div class="stat-item"><div class="stat-val">1300mm</div><div class="stat-label">Reach</div></div>
    </div>
  </div>
  <div class="hero-visual">
    <canvas id="robot-canvas"></canvas>
    <div class="canvas-overlay">
      <div class="status-dot"></div>
      <span>System status:</span>
      <strong>Operational</strong>
      <span>|</span>
      <span>Cycles:</span>
      <strong id="cycle-count">0</strong>
    </div>
  </div>
</section>

<section class="section">
  <div class="section-label">Capabilities</div>
  <div class="section-title">Everything your lab needs</div>
  <p class="section-sub">From sample intake to result reporting, LabForge handles the full automation stack.</p>
  <div class="features-grid">
    <div class="feature-card">
      <div class="feature-icon" style="background:rgba(0,98,255,.12)">🦾</div>
      <h3>6-Axis Freedom</h3>
      <p>Full articulation in confined lab spaces. The UR12e reaches every corner of your workstation without collision zones.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon" style="background:rgba(0,200,255,.1)">🧬</div>
      <h3>Liquid Handling</h3>
      <p>Sub-microliter precision pipetting with integrated vision guidance. Compatible with 96 and 384-well plates.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon" style="background:rgba(0,229,160,.1)">📡</div>
      <h3>Real-Time Monitoring</h3>
      <p>Live telemetry dashboards, instant alerts, and full audit trails for every sample movement and protocol step.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon" style="background:rgba(123,47,255,.1)">🔌</div>
      <h3>Open Integrations</h3>
      <p>Native plugins for Hamilton, Tecan, Beckman, and your LIMS. REST API and MQTT support out of the box.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon" style="background:rgba(255,180,0,.1)">🛡</div>
      <h3>ISO 15190 Safety</h3>
      <p>Force-limiting joints, collision detection, and proximity sensing — safe for staff in shared lab environments.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon" style="background:rgba(0,98,255,.12)">⚡</div>
      <h3>No-Code Protocols</h3>
      <p>Drag-and-drop workflow builder. Configure new assay protocols in minutes without writing a single line of code.</p>
    </div>
  </div>
</section>

<section class="section specs-section">
  <div class="specs-inner">
    <div>
      <div class="section-label">Technical Specs</div>
      <div class="section-title">UR12e Robot Arm</div>
      <table class="specs-table">
        <tr><td>Payload</td><td class="spec-highlight">12 kg</td></tr>
        <tr><td>Reach</td><td>1300 mm</td></tr>
        <tr><td>Repeatability</td><td class="spec-highlight">±0.03 mm</td></tr>
        <tr><td>Degrees of Freedom</td><td>6 joints</td></tr>
        <tr><td>Max TCP Speed</td><td>1.5 m/s</td></tr>
        <tr><td>Ingress Protection</td><td class="spec-highlight">IP54</td></tr>
        <tr><td>Collaborative Safety</td><td>ISO/TS 15066</td></tr>
        <tr><td>Power Consumption</td><td>200 W typical</td></tr>
        <tr><td>Weight</td><td>28.9 kg</td></tr>
        <tr><td>Temp. Range</td><td>0 – 50 °C</td></tr>
      </table>
    </div>
    <div class="spec-visual">
      <div style="font-size:.82rem;color:var(--muted);font-weight:600;text-transform:uppercase;letter-spacing:1px">Performance Benchmarks</div>
      <div>
        <div class="spec-bar-label"><span>Throughput Efficiency</span><span>97%</span></div>
        <div class="spec-bar-track"><div class="spec-bar-fill" style="width:97%"></div></div>
      </div>
      <div>
        <div class="spec-bar-label"><span>Positioning Accuracy</span><span>99.2%</span></div>
        <div class="spec-bar-track"><div class="spec-bar-fill" style="width:99.2%"></div></div>
      </div>
      <div>
        <div class="spec-bar-label"><span>Uptime (30-day avg)</span><span>99.8%</span></div>
        <div class="spec-bar-track"><div class="spec-bar-fill" style="width:99.8%"></div></div>
      </div>
      <div>
        <div class="spec-bar-label"><span>Protocol Success Rate</span><span>98.6%</span></div>
        <div class="spec-bar-track"><div class="spec-bar-fill" style="width:98.6%"></div></div>
      </div>
      <div>
        <div class="spec-bar-label"><span>Integration Coverage</span><span>84%</span></div>
        <div class="spec-bar-track"><div class="spec-bar-fill" style="width:84%"></div></div>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="section-label">How It Works</div>
  <div class="section-title">From setup to sample results</div>
  <div class="workflow-steps">
    <div class="workflow-step">
      <div class="step-num">01</div>
      <h4>Configure Protocol</h4>
      <p>Define your assay workflow with our drag-and-drop builder or import an existing SOP.</p>
    </div>
    <div class="workflow-step">
      <div class="step-num">02</div>
      <h4>Load Consumables</h4>
      <p>Place plates, tips, and reagents. Vision AI verifies deck layout before execution.</p>
    </div>
    <div class="workflow-step">
      <div class="step-num">03</div>
      <h4>Run & Monitor</h4>
      <p>UR12e executes autonomously. Live telemetry and alerts keep you informed in real time.</p>
    </div>
    <div class="workflow-step">
      <div class="step-num">04</div>
      <h4>Export Results</h4>
      <p>Data automatically syncs to your LIMS, ELN, or cloud storage with full audit trail.</p>
    </div>
  </div>
</section>

<section class="section" style="padding-top:0">
  <div class="section-label">Live Dashboard</div>
  <div class="section-title">Visibility into every run</div>
  <div class="dashboard-grid">
    <div class="metric-cards">
      <div class="metric-card">
        <div class="metric-val" style="color:var(--accent)" id="m-samples">2,841</div>
        <div class="metric-label">Samples Processed Today</div>
        <div class="metric-trend">↑ 12% vs yesterday</div>
      </div>
      <div class="metric-card">
        <div class="metric-val" style="color:var(--success)">99.8%</div>
        <div class="metric-label">System Uptime</div>
        <div class="metric-trend">↑ 0.2% this week</div>
      </div>
      <div class="metric-card">
        <div class="metric-val">7</div>
        <div class="metric-label">Protocols In Queue</div>
        <div class="metric-trend" style="color:var(--muted)">Next: Plate Wash 14:22</div>
      </div>
      <div class="metric-card">
        <div class="metric-val" style="color:var(--accent3)">±0.03</div>
        <div class="metric-label">mm Repeatability</div>
        <div class="metric-trend">Within spec</div>
      </div>
    </div>
    <div class="status-panel">
      <div class="panel-header">
        <h3>Active Protocols</h3>
        <div class="live-badge"><div class="status-dot" style="width:6px;height:6px"></div> Live</div>
      </div>
      <div class="task-row">
        <div class="task-dot" style="background:var(--accent);animation:pulse 1.5s infinite"></div>
        <div class="task-name">96-Well Liquid Transfer</div>
        <div class="task-status s-running">Running</div>
        <div class="task-time">2:14</div>
      </div>
      <div class="task-row">
        <div class="task-dot" style="background:var(--accent);animation:pulse 1.5s infinite .3s"></div>
        <div class="task-name">Plate Stacker Reload</div>
        <div class="task-status s-running">Running</div>
        <div class="task-time">0:47</div>
      </div>
      <div class="task-row">
        <div class="task-dot" style="background:var(--muted)"></div>
        <div class="task-name">PCR Prep — Batch 12</div>
        <div class="task-status s-queued">Queued</div>
        <div class="task-time">14:22</div>
      </div>
      <div class="task-row">
        <div class="task-dot" style="background:var(--muted)"></div>
        <div class="task-name">Reagent Replenishment</div>
        <div class="task-status s-queued">Queued</div>
        <div class="task-time">15:00</div>
      </div>
      <div class="task-row">
        <div class="task-dot" style="background:var(--success)"></div>
